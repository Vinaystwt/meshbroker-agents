# MeshBroker — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# X Layer Testnet RPC
RPC_URL=

# Deployed MeshBroker contract address
MESHBROKER_ADDRESS=

# MockUSDT token address
USDT_ADDRESS=

# Worker agent private key (hex, no 0x prefix)
WORKER_PRIVATE_KEY=

# Buyer + Verifier private key (same account in demo setup)
VERIFIER_PRIVATE_KEY=

# Verifier agent address (derived from VERIFIER_PRIVATE_KEY)
VERIFIER_AGENT_ADDRESS=

# Anthropic API key (for Claude Haiku composer)
ANTHROPIC_API_KEY=
